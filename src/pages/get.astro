---
import Base from '../layouts/Base.astro';
import Controls from '../components/Controls.astro';
import { site, base } from '../lib/site';
import { INSTALL, orderPorts } from '../data/install';

const accents = site.accents;
const h1 = 'get it';
const ports = orderPorts(site.ports);
const names = ports.map((p) => p.name);
const appList = names.slice(0, -1).join(', ') + ' and ' + names.at(-1);
const blurb = new Map(INSTALL.map((i) => [i.app, i.blurb]));
---
<Base
  title="enot - get it"
  desc={`Install the enot colorscheme: ${appList} - or add a port for another application.`}
  page="get/">
  <div class="hero wrap">
    <h1 style={`--h1ch:${h1.length}`}>{h1}</h1>
    <div class="tail" aria-hidden="true">{accents.map((r) => <i style={`background:var(--${r})`}></i>)}</div>
    <p class="tagline">Every port is generated from the same spec.</p>
    <p class="sub">Pick an application for the install steps; the full
    list of ports and their depths is in the
    <a href={`${base}apps/`}>coverage matrix</a>.</p>
    <Controls />
  </div>

  <section><div class="wrap">
    <div class="apps">
      {ports.map((p) => (
        <a class="app" href={`${base}${p.app}/`}><b>{p.name}</b>
        <span>{blurb.get(p.app) ?? `${p.depth}, ${p.guarantee} guarantee`}</span></a>
      ))}
      <a class="app ghost" href={`${base}apps/`}><b>add a port</b>
      <span>a port is a manifest the build renders from colors.json;
      the apps page lists them all and how to add one</span></a>
    </div>
  </div></section>

  <footer><div class="wrap">
    <span><a href={base}>&larr; enot</a> - an earthy colorscheme that survives color blindness.</span>
  </div></footer>
</Base>
