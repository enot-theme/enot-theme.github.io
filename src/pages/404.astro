---
import Base from '../layouts/Base.astro';
import { base } from '../lib/site';
---
<Base title="enot - page not found" desc="This page does not exist.">
  <div class="hero wrap">
    <img class="lost-art only-dark" src={`${base}mascot-dark.webp`} width="640" height="640" alt="the enot mascot looking judgmental" />
    <img class="lost-art only-light" src={`${base}mascot-light.webp`} width="640" height="640" alt="the enot mascot looking judgmental" />
    <h1 style="--h1ch:3">404</h1>
    <p class="tagline">This page slipped past the mask.</p>
    <div class="cta">
      <a class="btn" href={base}>Back to enot</a>
      <a class="btn alt" href={`${base}apps/`}>Applications</a>
    </div>
  </div>
</Base>
